{
  "name": "nidheesh-project",
  "private": true,
  "workspaces": [
    "hotels/react-app",
    "taste-explorer/react-app",
    "login/react-app"
  ],
  "scripts": {
    "dev:hotels": "npm --workspace hotels/react-app run dev",
    "dev:taste": "npm --workspace taste-explorer/react-app run dev",
    "dev:login": "npm --workspace login/react-app run dev",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed --workers=1",
    "test:e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0"
  }
}
